begin
    if old.tanggal_proses is distinct from new.tanggal_proses then
        raise exception 'gak iso le! tanggal proses giling tidak bisa diubah. hubungi admin nek perlu koreksi!';
    end if;
    return new;
end;
$$ language plpgsql;

create trigger trigger_proteksi_tanggal_proses
before update of tanggal_proses on proses_pabrik
for each row execute function fungsi_proteksi_tanggal_proses();


