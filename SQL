-- trigger 1: tambah stok pabrik
create or replace function fungsi_tambah_stok_gudang()
returns trigger as $$
declare
    v_berat_perubahan numeric(12,2) := 0.00;
    v_target_id int;
begin
    if tg_op = 'insert' then
        v_berat_perubahan := new.berat_output_green_bean_kg;
        v_target_id := new.id_stok_gudang;
    elsif tg_op = 'delete' then
        v_berat_perubahan := -old.berat_output_green_bean_kg;
        v_target_id := old.id_stok_gudang;
    elsif tg_op = 'update' then
        if old.id_stok_gudang is distinct from new.id_stok_gudang then
            update gudang_stok
            set total_berat_kg = total_berat_kg - old.berat_output_green_bean_kg,
                total_karung_tersedia = floor((total_berat_kg - old.berat_output_green_bean_kg) / 50.0)::int,
                last_update = current_timestamp
            where id_stok_gudang = old.id_stok_gudang;
            
            v_berat_perubahan := new.berat_output_green_bean_kg;
            v_target_id := new.id_stok_gudang;
        else
            v_berat_perubahan := new.berat_output_green_bean_kg - old.berat_output_green_bean_kg;
            v_target_id := new.id_stok_gudang;
        end if;
    end if;

    if v_target_id is not null then
        update gudang_stok
        set total_berat_kg = total_berat_kg + v_berat_perubahan,
            total_karung_tersedia = floor((total_berat_kg + v_berat_perubahan) / 50.0)::int,
            last_update = current_timestamp
        where id_stok_gudang = v_target_id;
    end if;

    return coalesce(new, old);
end;
$$ language plpgsql;

create trigger trigger_tambah_stok
after insert or update or delete on detail_proses_grade
for each row execute function fungsi_tambah_stok_gudang();


-- trigger 2: validasi stok jual & kunci (race condition fix)
create or replace function fungsi_validasi_stok_jual_secure()
returns trigger as $$
declare
    stok_sekarang int;
    perubahan_karung int;
begin
    if new.id_stok_gudang is null then
        raise exception 'gak iso le! referensi stok gudang ilang. hubungi admin!';
    end if;

    if tg_op = 'insert' then
        perubahan_karung := new.jumlah_karung_jual;
    elsif tg_op = 'update' then
        perubahan_karung := new.jumlah_karung_jual - old.jumlah_karung_jual;
    end if;

    if perubahan_karung > 0 then
        -- explicit lock: kunci baris stok agar tidak ada race condition kasir
        select total_karung_tersedia into stok_sekarang
        from gudang_stok
        where id_stok_gudang = new.id_stok_gudang
        for update; 

        if stok_sekarang is null then
            raise exception 'gak iso le! stok gudang id=% tidak ditemukan.', new.id_stok_gudang;
        end if;

        if stok_sekarang < perubahan_karung then
            raise exception 'gak iso le! stok id=% sisa % karung, mau ambil % karung. kurang le!',
                new.id_stok_gudang, stok_sekarang, perubahan_karung;
        end if;
    end if;

    return new;
end;
$$ language plpgsql;

create trigger trigger_cek_stok
before insert or update on detail_penjualan
for each row execute function fungsi_validasi_stok_jual_secure();


-- trigger 3: sinkronisasi berat kg + potong karung + hitung total nota
create or replace function fungsi_potong_stok_dan_hitung_total()
returns trigger as $$
begin
    if tg_op = 'insert' then
        if new.id_stok_gudang is not null then
            update gudang_stok
            set total_berat_kg = total_berat_kg - (new.jumlah_karung_jual * 50.0),
                total_karung_tersedia = floor((total_berat_kg - (new.jumlah_karung_jual * 50.0)) / 50.0)::int,
                last_update = current_timestamp
            where id_stok_gudang = new.id_stok_gudang;
        end if;
        
        update penjualan_gudang
        set total_bayar_seluruhnya = total_bayar_seluruhnya + new.subtotal_harga
        where id_penjualan = new.id_penjualan;

    elsif tg_op = 'delete' then
        if old.id_stok_gudang is not null then
            update gudang_stok
            set total_berat_kg = total_berat_kg + (old.jumlah_karung_jual * 50.0),
                total_karung_tersedia = floor((total_berat_kg + (old.jumlah_karung_jual * 50.0)) / 50.0)::int,
                last_update = current_timestamp
            where id_stok_gudang = old.id_stok_gudang;
        end if;

        update penjualan_gudang
        set total_bayar_seluruhnya = total_bayar_seluruhnya - old.subtotal_harga
        where id_penjualan = old.id_penjualan;

    elsif tg_op = 'update' then
        -- kembalikan stok lama
        if old.id_stok_gudang is not null then
            update gudang_stok
            set total_berat_kg = total_berat_kg + (old.jumlah_karung_jual * 50.0),
                total_karung_tersedia = floor((total_berat_kg + (old.jumlah_karung_jual * 50.0)) / 50.0)::int
            where id_stok_gudang = old.id_stok_gudang;
        end if;

        -- kurangi dengan stok baru
        if new.id_stok_gudang is not null then
            update gudang_stok
            set total_berat_kg = total_berat_kg - (new.jumlah_karung_jual * 50.0),
                total_karung_tersedia = floor((total_berat_kg - (new.jumlah_karung_jual * 50.0)) / 50.0)::int,
                last_update = current_timestamp
            where id_stok_gudang = new.id_stok_gudang;
        end if;

        -- update nota master
        update penjualan_gudang
        set total_bayar_seluruhnya = total_bayar_seluruhnya - old.subtotal_harga + new.subtotal_harga
        where id_penjualan = new.id_penjualan;
    end if;
    return coalesce(new, old);
end;
$$ language plpgsql;

create trigger trigger_final_nota
after insert or update or delete on detail_penjualan
for each row execute function fungsi_potong_stok_dan_hitung_total();


-- trigger 4: manajemen akun otomatis
create or replace function fungsi_manajemen_akun()
returns trigger as $$
declare
    v_status_sebelum_blokir varchar(20);
begin
    v_status_sebelum_blokir := new.status_akun;

    if new.salah_password_count >= 3 and new.status_akun = 'aktif' then
        new.status_akun := 'terblokir';
        insert into audit_log_sistem (username_eksekutor, aktivitas, keterangan)
        values (new.username, 'auto-blokir akun',
            format('akun "%s" otomatis diblokir sistem karena %s kali salah password.', new.username, new.salah_password_count));
        v_status_sebelum_blokir := 'sudah_dicatat';
    end if;

    if old.status_akun is distinct from new.status_akun and v_status_sebelum_blokir is distinct from 'sudah_dicatat' then
        insert into audit_log_sistem (username_eksekutor, aktivitas, keterangan)
        values ('system', 'perubahan status akun',
            format('akun "%s" status diubah dari "%s" ke "%s"', new.username, old.status_akun, new.status_akun));
    end if;

    if old.salah_password_count > 0 and new.salah_password_count = 0 then
        insert into audit_log_sistem (username_eksekutor, aktivitas, keterangan)
        values ('system', 'reset counter salah password',
            format('counter salah password akun "%s" di-reset dari %s ke 0', new.username, old.salah_password_count));
        
        if new.status_akun = 'terblokir' then
            new.status_akun := 'aktif';
            insert into audit_log_sistem (username_eksekutor, aktivitas, keterangan)
            values ('system', 'perubahan status akun',
                format('akun "%s" otomatis dibuka (unlock) karena counter di-reset ke 0.', new.username));
        end if;
    end if;

    return new;
end;
$$ language plpgsql;

create trigger trigger_manajemen_akun
before update of status_akun, salah_password_count on user_app
for each row execute function fungsi_manajemen_akun();


-- trigger 5: cegah input double 
-- (memberikan pesan kustom "duh gak iso le!" mendahului error constraint sistem)
create or replace function fungsi_cegah_double_panen()
returns trigger as $$
declare
    v_sudah_ada int;
begin
    select count(*) into v_sudah_ada
    from panen_kopi
    where id_blok = new.id_blok and tanggal_panen = new.tanggal_panen;

    if v_sudah_ada > 0 then
        raise exception 'duh gak iso le! blok "%" wes ada catatan panen tanggal %. coba pake fitur edit nek ingin ngubah datane.',
            new.id_blok, new.tanggal_panen;
    end if;
    return new;
end;
$$ language plpgsql;

create trigger trigger_anti_double_panen
before insert on panen_kopi
for each row execute function fungsi_cegah_double_panen();


-- trigger 6: proteksi tata letak rak gudang
create or replace function fungsi_validasi_tata_letak_rak()
returns trigger as $$
declare
    v_rak_terpakai int;
begin
    if new.lokasi_rak = 'belum diatur' or new.lokasi_rak is null then
        return new;
    end if;

    select count(*) into v_rak_terpakai
    from gudang_stok
    where lokasi_rak = new.lokasi_rak
      and id_stok_gudang != coalesce(new.id_stok_gudang, -1)
      and (jenis_kopi != new.jenis_kopi or grade_kualitas != new.grade_kualitas);

    if v_rak_terpakai > 0 then
        raise exception 'gagal! rak "%" wes dialokasikan untuk komoditas kopi/grade lain. ojhok dicampur stok barangnya le!', new.lokasi_rak;
    end if;
    return new;
end;
$$ language plpgsql;

create trigger trigger_proteksi_rak_insert
before insert on gudang_stok
for each row execute function fungsi_validasi_tata_letak_rak();

create trigger trigger_proteksi_rak_update
before update of lokasi_rak on gudang_stok
for each row execute function fungsi_validasi_tata_letak_rak();


-- trigger 7: validasi hukum fisika (output <= input)
create or replace function fungsi_validasi_fisika_giling()
returns trigger as $$
declare
    v_berat_input numeric;
    v_total_output_sekarang numeric;
begin
    select berat_input_panen_kg into v_berat_input
    from proses_pabrik
    where id_proses = new.id_proses;

    if v_berat_input is null then
        raise exception 'gagal! proses giling id=% tidak ditemukan atau data korup!', new.id_proses;
    end if;

    select coalesce(sum(berat_output_green_bean_kg), 0) into v_total_output_sekarang
    from detail_proses_grade
    where id_proses = new.id_proses
      and (id_detail_proses != new.id_detail_proses or new.id_detail_proses is null);

    if (v_total_output_sekarang + new.berat_output_green_bean_kg) > v_berat_input then
        raise exception 'ora masuk akal le! total output green bean (% kg) melebihi berat panen (% kg). cek timbangan!',
            to_char((v_total_output_sekarang + new.berat_output_green_bean_kg), 'fm999999990.00'),
            to_char(v_berat_input, 'fm999999990.00');
    end if;

    return new;
end;
$$ language plpgsql;

create trigger trigger_validasi_fisika_giling
before insert or update on detail_proses_grade
for each row execute function fungsi_validasi_fisika_giling();


-- trigger 8: proteksi riwayat tanggal proses pabrik
create or replace function fungsi_proteksi_tanggal_proses()
