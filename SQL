-- langkah 5: create stored procedure
-- =========================================

create or replace procedure sp_jalankan_transaksi_giling_secure(
    p_id_panen int,
    p_id_mesin varchar,
    p_metode_olah varchar,
    p_id_stok_gudang int,
    p_grade varchar,
    p_berat_in numeric,
    p_berat_out numeric
)
language plpgsql as $$
declare
    v_id_proses int;
    v_sudah_diproses int;
    v_status_mesin varchar(50);
    v_berat_panen numeric;
    v_stok_exists int;
begin
    set local lock_timeout = '3000ms';

    if p_metode_olah not in ('full wash', 'natural', 'honey', 'wet hull', 'dry process') then
        raise exception 'gak iso le! metode olah "%" tidak valid.', p_metode_olah;
    end if;

    select id_stok_gudang into v_stok_exists from gudang_stok where id_stok_gudang = p_id_stok_gudang for update;
    if v_stok_exists is null then
        raise exception 'gak iso le! stok gudang id=% tidak ditemukan.', p_id_stok_gudang;
    end if;

    select status_mesin into v_status_mesin from mesin_pabrik where id_mesin = p_id_mesin for update;
    if v_status_mesin is null then
        raise exception 'gak iso le! mesin "%" tidak ditemukan.', p_id_mesin;
    end if;
    if v_status_mesin in ('rusak', 'maintenance') then
        raise exception 'gak iso le! mesin "%" sedang dalam status "%".', p_id_mesin, v_status_mesin;
    end if;

    select berat_kopi_kg into v_berat_panen from panen_kopi where id_panen = p_id_panen for update;
    if v_berat_panen is null then
        raise exception 'gak iso le! data panen id=% tidak ditemukan.', p_id_panen;
    end if;
    if p_berat_in > v_berat_panen then
        raise exception 'gak iso le! berat input giling (% kg) melebihi berat panen aktual (% kg).',
            to_char(p_berat_in, 'fm999999990.00'), to_char(v_berat_panen, 'fm999999990.00');
    end if;

    select count(*) into v_sudah_diproses from proses_pabrik where id_panen = p_id_panen;
    if v_sudah_diproses > 0 then
        raise exception 'gak iso le! panen id=% wes pernah diproses giling. ojo double input!', p_id_panen;
    end if;

    insert into proses_pabrik (id_panen, id_mesin, metode_olah, berat_input_panen_kg)
    values (p_id_panen, p_id_mesin, p_metode_olah, p_berat_in)
    returning id_proses into v_id_proses;

    insert into detail_proses_grade (id_proses, id_stok_gudang, grade_kualitas, berat_output_green_bean_kg)
    values (v_id_proses, p_id_stok_gudang, p_grade, p_berat_out);

    insert into audit_log_sistem (username_eksekutor, aktivitas, keterangan)
    values ('system', 'grinding process completed',
        format('panen id=%s diproses giling dengan mesin %s, input=%s kg, output=%s kg, stok id=%s',
            p_id_panen, p_id_mesin, p_metode_olah, to_char(p_berat_in, 'fm999999990.00'), to_char(p_berat_out, 'fm999999990.00'), p_id_stok_gudang));
end;
$$;

