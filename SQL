-- buat otomatis nambah stok karung neng gudang iku coy, misal wes digiling
create or replace function fungsi_tambah_stok_gudang()
returns trigger as $$
begin
    update gudang_stok 
    set total_karung_tersedia = total_karung_tersedia + floor(new.berat_output_green_bean_kg / 50),
        last_update = current_timestamp
    where id_stok_gudang = new.id_stok_gudang;
    return new;
end;
$$ language plpgsql;

create trigger trigger_tambah_stok
after insert on detail_proses_grade
for each row execute function fungsi_tambah_stok_gudang();


-- iki biar gak balapan le, jadi anu, dikunci ngunu stoknya, biar gak oposeh, seng kondisi balapan ngunu pokok!!
-- ouh anuu le, iku dikunci ngunu sebelum seng kasir nyimpen barang penjualannya ikuu.
create or replace function fungsi_validasi_stok_jual_secure()
returns trigger as $$
declare
    stok_sekarang int;
begin
    select total_karung_tersedia into stok_sekarang 
    from gudang_stok 
    where id_stok_gudang = new.id_stok_gudang
    for update;
    
    if stok_sekarang < new.jumlah_karung_jual then
        raise exception 'gak iso le! gak onok space buat naruh karung lagi le or lagi diubah karo kasir lain le.';
    end if;
    return new;
end;
$$ language plpgsql;

create trigger trigger_cek_stok
before insert on detail_penjualan
for each row execute function fungsi_validasi_stok_jual_secure();


-- ikiii buat langsung ngurangin stok gudang pas dijual iku lee, sama buat ngitung harganya :V, semangatt beb ngerjainnya.
create or replace function fungsi_potong_stok_dan_hitung_total()
returns trigger as $$
begin
    update gudang_stok 
    set total_karung_tersedia = total_karung_tersedia - new.jumlah_karung_jual,
        last_update = current_timestamp
    where id_stok_gudang = new.id_stok_gudang;
    
    update penjualan_gudang
    set total_bayar_seluruhnya = total_bayar_seluruhnya + new.subtotal_harga
    where id_penjualan = new.id_penjualan;
    return new;
end;
$$ language plpgsql;

create trigger trigger_final_nota
after insert on detail_penjualan
for each row execute function fungsi_potong_stok_dan_hitung_total();


-- anuu le, buatinn fungsi seng otomatis ngeblokir misal salah input password teruss!!
create or replace function fungsi_auto_blokir_user()
returns trigger as $$
begin
    if new.salah_password_count >= 3 then
        new.status_akun := 'terblokir';
        insert into audit_log_sistem(username_eksekutor, aktivitas, keterangan)
        values (new.username, 'wes tak blok iku le :)', 'ojhok mekso, iku diblokir otomatis karo sistem, soale wes 3x salah password.');
    end if;
    return new;
end;
$$ language plpgsql;

create trigger trigger_auto_blokir
before update of salah_password_count on user_app
for each row execute function fungsi_auto_blokir_user();


-- buatinn anti humann error lee, koyok jangan sampe petani iku nginput data ning lahan seng sama hari ini.
create or replace function fungsi_cegah_double_panen()
returns trigger as $$
declare
    v_sudah_ada int;
begin
    select count(*) into v_sudah_ada 
    from panen_kopi 
    where id_blok = new.id_blok and tanggal_panen = current_date;

    if v_sudah_ada > 0 then
        raise exception 'duh gak iso le! blok lahan ini wes nyatet data panen dino iki. coba make fitur edit if ingin ngubah sikit sikit datane.';
    end if;
    return new;
end;
$$ language plpgsql;

create trigger trigger_anti_double_panen
before insert on panen_kopi
for each row execute function fungsi_cegah_double_panen();


-- buattt biar jenis kopinya gak kecampurr coy
create or replace function fungsi_validasi_tata_letak_rak()
returns trigger as $$
declare
    v_rak_terpakai int;
begin
    select count(*) into v_rak_terpakai
    from gudang_stok
    where lokasi_rak = new.lokasi_rak 
      and lokasi_rak != 'belum diatur'
      and (jenis_kopi != new.jenis_kopi or grade_kualitas != new.grade_kualitas);

    if v_rak_terpakai > 0 then
        raise exception 'gagallll!!! rak % wes dialokasikan untuk komoditas kopi jenis or grade lain. ojhok dicampur stok barangnya le!', new.lokasi_rak;
    end if;
    return new;
end;
$$ language plpgsql;

create trigger trigger_proteksi_rak_gudang
before update of lokasi_rak on gudang_stok
for each row execute function fungsi_validasi_tata_letak_rak();

-- [materi 9: stored procedure & transaction management - anti conflict run]
create or replace procedure sp_jalankan_transaksi_giling_secure(
    p_id_panen int,
    p_id_mesin varchar,
    p_metode_olah varchar,
    p_id_stok_gudang int,
    p_grade varchar,
    p_berat_in numeric,
    p_berat_out numeric
)
language plpgsql as $$
declare
    v_id_proses int;
begin
    -- mengunci batas toleransi antrean kunci data maksimal 3 detik agar c# tidak freeze
    set local lock_timeout = '3000';

    -- 1. catat kepala data ke proses_pabrik
    insert into proses_pabrik (id_panen, id_mesin, metode_olah, berat_input_panen_kg)
    values (p_id_panen, p_id_mesin, p_metode_olah, p_berat_in)
    returning id_proses into v_id_proses;
    
    -- 2. catat data detail grade (otomatis memicu penambahan stok via trigger 1)
    insert into detail_proses_grade (id_proses, id_stok_gudang, grade_kualitas, berat_output_green_bean_kg)
    values (v_id_proses, p_id_stok_gudang, p_grade, p_berat_out);
    
exception
    when others then
        raise exception 'transaksi pabrik digagalkan karo : %', sqlerrm;
end;
$$;

