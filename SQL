create or replace view v_stok_gudang_ready as
select id_stok_gudang, jenis_kopi, grade_kualitas, total_karung_tersedia, lokasi_rak
from gudang_stok;

create or replace view v_detail_penjualan_lengkap as
select 
    pg.id_penjualan,
    mb.nama_perusahaan as nama_pembeli,
    pg.tanggal_jual,
    gs.jenis_kopi,
    dp.jumlah_karung_jual,
    dp.subtotal_harga,
    pg.total_bayar_seluruhnya
from detail_penjualan dp
join penjualan_gudang pg on dp.id_penjualan = pg.id_penjualan
join gudang_stok gs on dp.id_stok_gudang = gs.id_stok_gudang
join mitra_pembeli mb on pg.id_mitra = mb.id_mitra;

