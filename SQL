-- iki buat data masternya woy
create table mitra_pembeli (
    id_mitra varchar(50) primary key,
    nama_perusahaan varchar(150) not null,
    alamat_kantor text,
    kontak_pembeli varchar(50)
);

create table pabrik (
    id_pabrik varchar(50) primary key,
    nama_pabrik varchar(100) not null,
    lokasi_pabrik varchar(100) not null,
    kapasitas_harian_kg numeric(10,2)
);

create table mesin_pabrik (
    id_mesin varchar(50) primary key,
    id_pabrik varchar(50) references pabrik(id_pabrik) on update cascade on delete cascade,
    nama_mesin varchar(100) not null,
    kapasitas_kg int not null,
    status_mesin varchar(50) default 'normal'
);

create table role_app (
    id_role serial primary key,
    nama_role varchar(50) unique not null
);

create table karyawan (
    id_karyawan varchar(100) primary key,
    nama_karyawan varchar(150) not null,
    jabatan varchar(100) not null,
    no_telp varchar(20)
);

create table user_app (
    id_user serial primary key,
    id_karyawan varchar(100) unique references karyawan(id_karyawan) on update cascade on delete cascade,
    username varchar(50) unique not null,
    password_hash varchar(64) not null,
    id_role int references role_app(id_role) on update cascade on delete set null,
    status_verif2step boolean default false not null,
    kode_hash_verif2step varchar(200) default null,
    salah_password_count int default 0,
    status_akun varchar(20) default 'aktif',
    created_at timestamp default current_timestamp
);

create table afdeling (
    id_afdeling varchar(50) primary key,
    nama_afdeling varchar(100) not null,
    id_user_sinder int references user_app(id_user) on update cascade on delete set null
);

create table blok_lahan (
    id_blok varchar(50) primary key,
    id_afdeling varchar(50) references afdeling(id_afdeling) on update cascade on delete cascade,
    nama_blok varchar(100) not null,
    luas_hektar numeric(10,2) not null,
    kondisi_tanaman varchar(100) default 'baik'
);

-- ikii apa wess, lupa wehhh, kayak e tabel operasional seng iki
create table panen_kopi (
    id_panen serial primary key,
    id_blok varchar(50) references blok_lahan(id_blok) on update cascade on delete cascade,
    id_user_mandor int references user_app(id_user) on update cascade on delete set null,
    tanggal_panen date default current_date,
    berat_kopi_kg numeric(10,2) not null,
    catatan text
);

create table proses_pabrik (
    id_proses serial primary key,
    id_panen int references panen_kopi(id_panen) on update cascade on delete cascade,
    id_mesin varchar(50) references mesin_pabrik(id_mesin) on update cascade on delete set null,
    tanggal_proses date default current_date,
    metode_olah varchar(50) not null, 
    berat_input_panen_kg numeric(10,2) not null 
);

create table gudang_stok (
    id_stok_gudang serial primary key,
    jenis_kopi varchar(100) not null,   
    grade_kualitas varchar(10) not null, 
    total_karung_tersedia int default 0, 
    lokasi_rak varchar(50) default 'belum diatur',
    last_update timestamp default current_timestamp,
    constraint unique_kopi_grade unique (jenis_kopi, grade_kualitas)
);

create table detail_proses_grade (
    id_detail_proses serial primary key,
    id_proses int references proses_pabrik(id_proses) on update cascade on delete cascade,
    id_stok_gudang int references gudang_stok(id_stok_gudang) on update cascade on delete set null, 
    grade_kualitas varchar(10) not null, 
    berat_output_green_bean_kg numeric(10,2) not null
);

create table penjualan_gudang (
    id_penjualan serial primary key,
    id_mitra varchar(50) references mitra_pembeli(id_mitra) on update cascade on delete set null,
    tanggal_jual date default current_date,
    total_bayar_seluruhnya numeric(15,2) default 0.00
);

create table detail_penjualan (
    id_detail_jual serial primary key,
    id_penjualan int references penjualan_gudang(id_penjualan) on update cascade on delete cascade,
    id_stok_gudang int references gudang_stok(id_stok_gudang) on update cascade on delete set null,
    jumlah_karung_jual int not null,
    harga_per_karung numeric(15,2) not null,
    subtotal_harga numeric(15,2) not null
);

create table audit_log_sistem (
    id_log serial primary key,
    username_eksekutor varchar(50) default 'system',
    aktivitas varchar(100) not null,
    keterangan text,
    waktu_kejadian timestamp default current_timestamp
);

